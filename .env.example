APP_NAME=ScoutDash
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://scoutdash:scoutdash@postgres:5432/scoutdash

