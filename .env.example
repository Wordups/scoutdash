APP_NAME=ScoutDash
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://scoutdash:scoutdash@postgres:5432/scoutdash

STORAGE_BACKEND=s3
LOCAL_UPLOAD_DIR=./data/uploads
LOCAL_STORAGE_PERSISTENT=false
PUBLIC_MEDIA_BASE_URL=http://localhost:8000/media

S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=scoutdash-film
S3_ACCESS_KEY_ID=scoutdash
S3_SECRET_ACCESS_KEY=scoutdash-secret
S3_REGION=us-east-1
S3_PRESIGNED_URL_TTL_SECONDS=3600

# Optional overrides. The backend otherwise uses system FFmpeg, then its bundled fallback.
FFMPEG_BINARY=
FFPROBE_BINARY=

# SAM3 player tracking (separate Modal GPU worker — see services/sam3-worker/).
# Leave both unset to disable: track seeds still save, just without auto-tracking.
# SAM3_WORKER_URL = the worker's /dispatch endpoint URL printed by `modal deploy`.
# INTERNAL_API_TOKEN = shared secret; must equal the worker's INTERNAL_TOKEN secret.
SAM3_WORKER_URL=
INTERNAL_API_TOKEN=

NEXT_PUBLIC_API_URL=http://localhost:8000/api
